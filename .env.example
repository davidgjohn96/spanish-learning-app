# Copy this file to `.env.local` and fill in values from the Supabase dashboard
# (Project Settings → API). The .local suffix means Vite loads it automatically
# and it never gets committed.
#
# VITE_ prefix is required by Vite to expose vars to the front-end bundle.
# The anon key is safe to ship in the bundle — it's gated by row-level
# security policies enforced by Postgres.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
